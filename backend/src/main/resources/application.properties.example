spring.application.name=OnlineCabBookingSystem

spring.datasource.url=jdbc:h2:mem:testdb
spring.datasource.driver-class-name=org.h2.Driver
spring.datasource.username=sa
spring.datasource.password=
ors.api.key=YOUR_OPENROUTESERVICE_API_KEY_HERE

spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true

spring.h2.console.enabled=true
spring.h2.console.path=/h2-console
spring.h2.console.settings.web-allow-others=true
twilio.account.Sid=YOUR_TWILIO_SID_HERE
twilio.auth.Token=YOUR_TWILIO_AUTH_TOKEN_HERE
twilio.phone.Number=+YOUR_TWILIO_NUMBER_HERE
